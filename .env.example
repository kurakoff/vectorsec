# === Режим работы ===
# Для работы с УДАЛЁННОЙ БД (продакшен данные):
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@SERVER_IP:5432/DB_NAME

# Для работы с ЛОКАЛЬНОЙ БД (своя пустая база):
# DATABASE_URL=postgresql+asyncpg://vectorsec:vectorsec@db:5432/vectorsec

# Настройки локальной БД
POSTGRES_USER=vectorsec
POSTGRES_PASSWORD=vectorsec
POSTGRES_DB=vectorsec
